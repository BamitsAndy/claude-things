{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "plansDirectory": "./plans",
  "defaultMode": "plan",
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "ask":[
      "Bash",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "NotebookEdit",
      "LSP"
    ]
  },
  "defer_loading": true
}
